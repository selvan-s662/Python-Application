pipeline {
    agent any

    environment {
        IMAGE_NAME = "localhost:5000/python-demo:v1"
    }

    stages {
        stage('Clone') {
            steps {
                // Clone source code from GitHub
                git branch: 'main', url: 'https://github.com/selvan-s662/Python-Application.git'
            }
        }

        stage('Build') {
            steps {
                // Build Docker image
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }

        stage('Push') {
            steps {
                // Push Docker image to local registry
                sh "docker push ${IMAGE_NAME}"
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs.'
        }
    }
}

